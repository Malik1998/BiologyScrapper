# OpenRouter API key - enables the llm_align / vlm_verify filters and the
# optional identity-research step in the load_subjects stage.
OPENROUTER_API_KEY=

# Optional HTTP(S)/SOCKS proxy used only for OpenRouter requests, e.g.
# "http://user:pass@host:port" or "socks5h://host:port". Needed if the
# machine running this pipeline is on a network OpenRouter's edge blocks
# outright ("Access denied by security policy" regardless of model/key) -
# see README > "LLM telemetry".
OPENROUTER_PROXY_URL=

# Alternative to OPENROUTER_PROXY_URL: point requests at your own relay
# (relay/app.py) running on a server that isn't blocked, instead of
# openrouter.ai directly. Set to e.g. "http://relay-host:8787" (no trailing
# path - /api/v1/chat/completions is appended automatically). The relay has
# no auth of its own, so keep it firewalled to trusted IPs only.
OPENROUTER_BASE_URL=

# Optional paid image search backends - only needed if config/pipeline.yaml
# sets search_images.backend to "serpapi" or "bing".
SERPAPI_KEY=
BING_SEARCH_KEY=

# Log verbosity for both the CLI pipeline and the web app (DEBUG/INFO/WARNING/...).
LOG_LEVEL=INFO

# Optional: send every OpenRouter call as a trace to a self-hosted Langfuse
# instance (see README > "LLM telemetry"). Leave blank to disable tracing -
# the pipeline runs the same either way, only the local logs are affected.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
