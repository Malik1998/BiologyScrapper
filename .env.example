# OpenRouter API key - enables the llm_align / vlm_verify filters and the
# optional identity-research step in the load_subjects stage.
OPENROUTER_API_KEY=

# Optional paid image search backends - only needed if config/pipeline.yaml
# sets search_images.backend to "serpapi" or "bing".
SERPAPI_KEY=
BING_SEARCH_KEY=

# Log verbosity for both the CLI pipeline and the web app (DEBUG/INFO/WARNING/...).
LOG_LEVEL=INFO

# Optional: send every OpenRouter call as a trace to a self-hosted Langfuse
# instance (see README > "LLM telemetry"). Leave blank to disable tracing -
# the pipeline runs the same either way, only the local logs are affected.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
